<UserControl
    x:Class="OmniPlay.UI.Views.Library.PosterWallView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:brand="using:OmniPlay.UI.Controls.Brand"
    xmlns:converters="using:OmniPlay.UI.Converters"
    xmlns:player="using:OmniPlay.UI.Controls.Player">
  <UserControl.Resources>
    <converters:ImagePathToBitmapConverter x:Key="ImagePathToBitmapConverter" />
  </UserControl.Resources>
  <UserControl.Styles>
    <Style Selector="Button">
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>
    <Style Selector="Border.homeSurface">
      <Setter Property="Background" Value="#F3F3F7" />
    </Style>
    <Style Selector="Border.detailSurface">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#D8E1F2" Offset="0" />
          <GradientStop Color="#E9D7EC" Offset="0.32" />
          <GradientStop Color="#D9DBEE" Offset="0.7" />
          <GradientStop Color="#D4DBEE" Offset="1" />
        </LinearGradientBrush>
      </Setter>
    </Style>
    <Style Selector="Border.toolbarGroup">
      <Setter Property="Background" Value="#00000000" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Border.sectionDivider">
      <Setter Property="Background" Value="#D1D2DA" />
      <Setter Property="Height" Value="1" />
    </Style>
    <Style Selector="Border.posterShell">
      <Setter Property="CornerRadius" Value="26" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="BoxShadow" Value="0 18 38 0 #18000000" />
      <Setter Property="Background" Value="#E4E6F0" />
    </Style>
    <Style Selector="Border.ratingBadge">
      <Setter Property="Background" Value="#B6121216" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="9,6" />
    </Style>
    <Style Selector="Border.watchStateBadge">
      <Setter Property="Background" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
    </Style>
    <Style Selector="Path.watchStateIcon">
      <Setter Property="Stroke" Value="#545C69" />
      <Setter Property="StrokeThickness" Value="1.9" />
      <Setter Property="StrokeLineCap" Value="Round" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
    </Style>
    <Style Selector="Ellipse.watchStateRing">
      <Setter Property="Stroke" Value="#545C69" />
      <Setter Property="StrokeThickness" Value="1.9" />
      <Setter Property="Width" Value="17" />
      <Setter Property="Height" Value="17" />
    </Style>
    <Style Selector="Ellipse.watchStateDot">
      <Setter Property="Fill" Value="#545C69" />
      <Setter Property="Width" Value="7" />
      <Setter Property="Height" Value="7" />
    </Style>
    <Style Selector="Button.watchStateButton">
      <Setter Property="Background" Value="#00000000" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="MinWidth" Value="30" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="CornerRadius" Value="15" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.watchStateButton:pointerover">
      <Setter Property="Background" Value="#E2E5ED" />
    </Style>
    <Style Selector="Button.watchStateButton:pressed">
      <Setter Property="Background" Value="#D5D9E4" />
    </Style>
    <Style Selector="Border.detailMetaBadge">
      <Setter Property="Background" Value="#F7F8FC" />
      <Setter Property="BorderBrush" Value="#E0E3EC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="16,10" />
    </Style>
    <Style Selector="Border.lockStateLocked">
      <Setter Property="Background" Value="#FFF4E8" />
      <Setter Property="BorderBrush" Value="#F0C48D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="15" />
      <Setter Property="Padding" Value="14,8" />
    </Style>
    <Style Selector="Border.lockStateUnlocked">
      <Setter Property="Background" Value="#EDF5FF" />
      <Setter Property="BorderBrush" Value="#B9D5FF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="15" />
      <Setter Property="Padding" Value="14,8" />
    </Style>
    <Style Selector="Button.iconCircle">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Width" Value="74" />
      <Setter Property="Height" Value="74" />
      <Setter Property="MinWidth" Value="74" />
      <Setter Property="MinHeight" Value="74" />
      <Setter Property="CornerRadius" Value="37" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.iconCircle:pointerover">
      <Setter Property="Background" Value="#F1F4FA" />
    </Style>
    <Style Selector="Button.iconCircle:pressed">
      <Setter Property="Background" Value="#E6EAF2" />
    </Style>
    <Style Selector="Path.iconStroke">
      <Setter Property="Stroke" Value="#7D7D84" />
      <Setter Property="StrokeThickness" Value="2.1" />
      <Setter Property="StrokeLineCap" Value="Round" />
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
    </Style>
    <Style Selector="Path.iconFill">
      <Setter Property="Fill" Value="#7D7D84" />
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Stretch" Value="Uniform" />
    </Style>
    <Style Selector="Button.flatIcon">
      <Setter Property="Background" Value="#00000000" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Width" Value="48" />
      <Setter Property="Height" Value="48" />
      <Setter Property="MinWidth" Value="48" />
      <Setter Property="MinHeight" Value="48" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.flatIcon:pointerover">
      <Setter Property="Background" Value="#F1F2F6" />
    </Style>
    <Style Selector="Button.flatIcon:pressed">
      <Setter Property="Background" Value="#E8EAF0" />
    </Style>
    <Style Selector="Button.posterQuickAction">
      <Setter Property="Background" Value="#E8FFFFFF" />
      <Setter Property="BorderBrush" Value="#55FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="CornerRadius" Value="17" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.posterQuickAction:pointerover">
      <Setter Property="Background" Value="#FFFFFFFF" />
      <Setter Property="BorderBrush" Value="#88FFFFFF" />
    </Style>
    <Style Selector="Button.posterQuickAction Path">
      <Setter Property="Stroke" Value="#22252B" />
      <Setter Property="StrokeThickness" Value="2" />
      <Setter Property="StrokeLineCap" Value="Round" />
      <Setter Property="Stretch" Value="Uniform" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
    </Style>
    <Style Selector="StackPanel.posterQuickActions">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <Style Selector="Grid.posterInteractive:pointerover StackPanel.posterQuickActions">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="Button.cardButton">
      <Setter Property="Background" Value="#00000000" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Top" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.heroAction">
      <Setter Property="Background" Value="#267CFF" />
      <Setter Property="BorderBrush" Value="#267CFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="28" />
      <Setter Property="Padding" Value="30,17" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="28" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.heroAction:pointerover">
      <Setter Property="Background" Value="#1F70EA" />
      <Setter Property="BorderBrush" Value="#1F70EA" />
    </Style>
    <Style Selector="Button.heroSecondary">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="28" />
      <Setter Property="Padding" Value="26,17" />
      <Setter Property="Foreground" Value="#101114" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="24" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.heroSecondary:pointerover">
      <Setter Property="Background" Value="#F3F5FA" />
    </Style>
    <Style Selector="Button.sourceAction">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="Foreground" Value="#111215" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.sourceAction:pointerover">
      <Setter Property="Background" Value="#F7F7FA" />
    </Style>
    <Style Selector="Button.networkLinkAction">
      <Setter Property="Background" Value="#00000000" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="#2E65D6" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.networkLinkAction:pointerover">
      <Setter Property="Foreground" Value="#174EA6" />
    </Style>
    <Style Selector="Button.sortOption">
      <Setter Property="Background" Value="#00000000" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.sortOption:pointerover">
      <Setter Property="Background" Value="#F1F2F6" />
    </Style>
    <Style Selector="Border.popupPanel">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#DEDFE6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="BoxShadow" Value="0 18 36 0 #18000000" />
    </Style>
    <Style Selector="TextBox.popupSearchBox">
      <Setter Property="Background" Value="#F6F7FA" />
      <Setter Property="BorderBrush" Value="#DADCE5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="16,12" />
    </Style>
    <Style Selector="ComboBox.popupSelect">
      <Setter Property="Background" Value="#F6F7FA" />
      <Setter Property="BorderBrush" Value="#DADCE5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="14,10" />
    </Style>
    <Style Selector="Button.dangerAction">
      <Setter Property="Background" Value="#FFF1EF" />
      <Setter Property="BorderBrush" Value="#E7BDB5" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Foreground" Value="#8B342B" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter
                Margin="{TemplateBinding Padding}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="{TemplateBinding Content}"
                ContentTemplate="{TemplateBinding ContentTemplate}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.dangerAction:pointerover">
      <Setter Property="Background" Value="#FDE6E1" />
    </Style>
    <Style Selector="Border.progressTrack">
      <Setter Property="Background" Value="#DBDDE5" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Height" Value="6" />
    </Style>
    <Style Selector="ProgressBar.libraryProgress">
      <Setter Property="Foreground" Value="#1C7BFF" />
      <Setter Property="Background" Value="#D8DAE3" />
      <Setter Property="Height" Value="6" />
      <Setter Property="CornerRadius" Value="999" />
    </Style>
    <Style Selector="Border.detailPanel">
      <Setter Property="Background" Value="#F7F8FC" />
      <Setter Property="BorderBrush" Value="#DEE1EC" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="26" />
      <Setter Property="BoxShadow" Value="0 16 34 0 #12000000" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,Auto">
    <Border Grid.Row="0" Classes="homeSurface" IsVisible="{Binding !IsDetailOpen}">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="HomeContentStack" Margin="52,4,52,40" Spacing="6">
          <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" IsVisible="{Binding HasStatusMessage}">
              <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="#8A8A92" Text="{Binding StatusMessage}" />
            </StackPanel>

            <Border Grid.Column="1" Classes="toolbarGroup">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Button x:Name="SourceButton" Classes="flatIcon" Command="{Binding ToggleSourcePopupCommand}" ToolTip.Tip="&#x5A92;&#x4F53;&#x5E93;">
                  <Grid Width="28" Height="28">
                    <Path Classes="iconStroke" Data="M5,21 H23 V11 H13.8 L11.6,8.5 H5 Z" />
                  </Grid>
                </Button>
                <Button Classes="flatIcon" Command="{Binding ScanCommand}" ToolTip.Tip="&#x626B;&#x63CF;&#x5A92;&#x4F53;&#x5E93;">
                  <Grid Width="28" Height="28">
                    <Path Classes="iconStroke" Data="M20.5,10.2 A7.8,7.8 0 0 0 8,8.4 M20.5,6.5 V10.2 H16.8" />
                    <Path Classes="iconStroke" Data="M7.5,17.8 A7.8,7.8 0 0 0 20,19.6 M7.5,21.5 V17.8 H11.2" />
                  </Grid>
                </Button>
                <Button x:Name="SettingsButton" Classes="flatIcon" Command="{Binding ToggleSettingsPopupCommand}" ToolTip.Tip="&#x8BBE;&#x7F6E;">
                  <Grid Width="28" Height="28">
                    <Path Classes="iconStroke" Data="M14,4.5 L16,5 L16.7,7.2 L18.6,8 L20.7,7 L22,9.2 L20.6,11 L21.1,13 L23,14 L22.2,16.5 L20,16.9 L18.8,18.6 L19.1,20.9 L16.9,22.1 L15.2,20.6 H12.8 L11.1,22.1 L8.9,20.9 L9.2,18.6 L8,16.9 L5.8,16.5 L5,14 L6.9,13 L7.4,11 L6,9.2 L7.3,7 L9.4,8 L11.3,7.2 L12,5 Z" />
                    <Ellipse Width="7" Height="7" HorizontalAlignment="Center" VerticalAlignment="Center" Stroke="#7D7D84" StrokeThickness="2.1" />
                  </Grid>
                </Button>
              </StackPanel>
            </Border>
          </Grid>

          <Popup IsLightDismissEnabled="True" IsOpen="{Binding IsSearchPopupOpen}" Placement="Bottom" PlacementTarget="{Binding #SearchButton}">
            <Border Classes="popupPanel" Width="340" Padding="20">
              <StackPanel Spacing="14">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="&#x641C;&#x7D22;" />
                <TextBox Classes="popupSearchBox" Watermark="&#x8F93;&#x5165;&#x7535;&#x5F71;&#x6216;&#x5267;&#x96C6;&#x6807;&#x9898;" Text="{Binding SearchText}" />
              </StackPanel>
            </Border>
          </Popup>

          <Popup IsLightDismissEnabled="True" IsOpen="{Binding IsSortPopupOpen}" Placement="Bottom" PlacementTarget="{Binding #SortButton}">
            <Border Classes="popupPanel" Width="240" Padding="14">
              <StackPanel Spacing="6">
                <TextBlock Margin="8,4,8,8" FontSize="20" FontWeight="SemiBold" Text="&#x6392;&#x5E8F;" />
                <ItemsControl ItemsSource="{Binding SortOptions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Classes="sortOption" Command="{Binding $parent[UserControl].DataContext.SelectSortOptionCommand}" CommandParameter="{Binding}">
                        <TextBlock FontSize="16" Text="{Binding Label}" />
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </Popup>

          <Popup IsLightDismissEnabled="True" IsOpen="{Binding IsSourcePopupOpen}" Placement="Bottom" PlacementTarget="{Binding #SourceButton}">
            <Border Classes="popupPanel" Width="560" MaxHeight="760" Padding="20">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                  <StackPanel Spacing="16">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="已挂载媒体源" />

                  <StackPanel Spacing="10">
                    <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="14" IsVisible="{Binding !HasMediaSources}">
                      <TextBlock Opacity="0.66" Text="暂无媒体源" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding MediaSources}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                              <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                              <Button Grid.Column="1" Margin="10,0,10,0" Classes="sourceAction" Command="{Binding $parent[UserControl].DataContext.ToggleSourceEnabledCommand}" CommandParameter="{Binding}" Content="{Binding ToggleActionText}" />
                              <Button Grid.Column="2" Classes="dangerAction" Command="{Binding $parent[UserControl].DataContext.RemoveSourceCommand}" CommandParameter="{Binding}" Content="移除" />
                              <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,8,0,0" Orientation="Horizontal" Spacing="8">
                                <TextBlock Opacity="0.72" Text="{Binding ProtocolLabel}" />
                                <TextBlock Opacity="0.72" Text="·" />
                                <TextBlock Opacity="0.72" Text="{Binding SourceStateText}" />
                              </StackPanel>
                              <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Margin="0,6,0,0" IsVisible="{Binding $parent[UserControl].DataContext.ShowMediaSourceRealPath}" Opacity="0.62" Text="{Binding BaseUrl}" TextWrapping="Wrap" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>

                  <StackPanel Spacing="10">
                    <Button Classes="sourceAction" Background="#F6F7FA" BorderBrush="#DADCE5" BorderThickness="1" Command="{Binding AddFolderSourceCommand}" Content="添加本地文件夹" />
                    <Button Classes="sourceAction" Background="#F6F7FA" BorderBrush="#DADCE5" BorderThickness="1" Command="{Binding OpenManualNetworkLoginCommand}" Content="添加局域网媒体源" />
                  </StackPanel>

                  <Border Height="1" Background="#E3E4EA" />

                  <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="16" IsVisible="{Binding IsNetworkLoginPanelOpen}">
                    <StackPanel Spacing="12">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock FontWeight="SemiBold" Text="{Binding NetworkLoginTitle}" />
                        <Button Grid.Column="1" Classes="dangerAction" Command="{Binding CloseNetworkLoginCommand}" Content="取消" />
                      </Grid>
                      <TextBox Classes="popupSearchBox" Watermark="WebDAV 地址或 SMB 路径" Text="{Binding PendingNetworkBaseUrl}" />
                      <Grid ColumnDefinitions="*,*">
                        <TextBox Classes="popupSearchBox" Watermark="用户名（可选）" Text="{Binding PendingNetworkUsername}" />
                        <TextBox Grid.Column="1" Margin="10,0,0,0" Classes="popupSearchBox" Watermark="密码（可选）" Text="{Binding PendingNetworkPassword}" />
                      </Grid>
                      <Button Classes="sourceAction" HorizontalAlignment="Left" Command="{Binding SaveNetworkLoginCommand}" Content="保存并读取共享文件夹" />
                      <ItemsControl ItemsSource="{Binding NetworkShareFolders}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="#FFFFFF" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="1" Classes="sourceAction" Command="{Binding $parent[UserControl].DataContext.MountNetworkFolderCommand}" CommandParameter="{Binding}" Content="★" ToolTip.Tip="挂载到媒体源" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>

                  <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock FontSize="17" FontWeight="SemiBold" Text="预扫描 SMB / WebDAV" />
                      <Button Grid.Column="1" Classes="sourceAction" Command="{Binding RefreshNetworkSourcesCommand}" Content="重新扫描" />
                    </Grid>
                    <TextBlock Opacity="0.62" TextWrapping="Wrap" Text="{Binding NetworkSourceStatus}" />
                    <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="14" IsVisible="{Binding !HasDiscoveredNetworkSources}">
                      <TextBlock Opacity="0.66" Text="暂无预扫描结果" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding DiscoveredNetworkSources}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                              <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1" Opacity="0.68" Text="{Binding ProtocolLabel}" />
                              <Button Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0" Classes="networkLinkAction" Command="{Binding $parent[UserControl].DataContext.OpenNetworkLoginCommand}" CommandParameter="{Binding}">
                                <TextBlock Text="{Binding BaseUrl}" TextWrapping="Wrap" />
                              </Button>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Popup>

          <Popup IsLightDismissEnabled="True" IsOpen="{Binding IsSettingsPopupOpen}" Placement="Bottom" PlacementTarget="{Binding #SettingsButton}">
            <Border Classes="popupPanel" Width="460" MaxHeight="720" Padding="20">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16">
                  <TextBlock FontSize="20" FontWeight="SemiBold" Text="&#x8BBE;&#x7F6E;" />

                  <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel Spacing="14">
                      <TextBlock FontWeight="SemiBold" Text="&#x57FA;&#x7840;&#x8BBE;&#x7F6E;" />
                      <CheckBox IsChecked="{Binding Settings.AutoScanOnStartup}" Content="&#x542F;&#x52A8;&#x65F6;&#x81EA;&#x52A8;&#x626B;&#x63CF;&#x5E76;&#x540C;&#x6B65;&#x5E93;" />
                      <CheckBox IsChecked="{Binding Settings.ShowMediaSourceRealPath}" Content="&#x5A92;&#x4F53;&#x6E90;&#x663E;&#x793A;&#x771F;&#x5B9E;&#x8DEF;&#x5F84;" />
                    </StackPanel>
                  </Border>

                  <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel Spacing="14">
                      <CheckBox IsChecked="{Binding Settings.EnableBuiltInPublicTmdbSource}" Content="启用内置公共 TMDB 源（受限）" />
                      <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="自定义 TMDB API" />
                        <TextBox Classes="popupSearchBox" Watermark="API Key 或 Read Access Token" Text="{Binding Settings.CustomTmdbCredential}" />
                      </StackPanel>
                      <StackPanel Spacing="10">
                        <TextBlock Opacity="0.72" TextWrapping="Wrap" Text="{Binding Settings.TmdbConnectionStatusMessage}" />
                        <Button Classes="sourceAction" Command="{Binding Settings.TestTmdbConnectionCommand}" Content="测试连通性" />
                      </StackPanel>
                      <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="软件和刮削语言" />
                        <ComboBox
                            Classes="popupSelect"
                            ItemsSource="{Binding Settings.TmdbLanguageOptions}"
                            SelectedItem="{Binding Settings.SelectedTmdbLanguageOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel Spacing="14">
                      <TextBlock FontWeight="SemiBold" Text="播放偏好" />
                      <StackPanel Spacing="8">
                        <TextBlock Text="默认音轨" />
                        <ComboBox
                            Classes="popupSelect"
                            ItemsSource="{Binding Settings.DefaultAudioTrackOptions}"
                            SelectedItem="{Binding Settings.SelectedDefaultAudioTrackOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </StackPanel>
                      <StackPanel Spacing="8">
                        <TextBlock Text="默认字幕" />
                        <ComboBox
                            Classes="popupSelect"
                            ItemsSource="{Binding Settings.DefaultSubtitleTrackOptions}"
                            SelectedItem="{Binding Settings.SelectedDefaultSubtitleTrackOption, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel Spacing="12">
                      <TextBlock FontWeight="SemiBold" Text="播放器内核" />
                      <TextBlock Opacity="0.72" TextWrapping="Wrap" Text="{Binding Player.BackendName}" />
                      <TextBlock FontWeight="SemiBold" Text="开源组件" />
                      <ItemsControl ItemsSource="{Binding Settings.CreditLinks}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid Margin="0,0,0,6" ColumnDefinitions="*,Auto,Auto">
                              <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1" Margin="10,0,0,0" Opacity="0.62" Text="{Binding License}" />
                              <Button
                                  Grid.Column="2"
                                  Margin="8,0,0,0"
                                  Classes="sourceAction"
                                  Padding="10,6"
                                  Command="{Binding $parent[UserControl].DataContext.Settings.OpenCreditLinkCommand}"
                                  CommandParameter="{Binding}"
                                  Content="网页" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="sourceAction" Command="{Binding Settings.OpenAboutCommand}" Content="关于" />
                        <Button Classes="sourceAction" Command="{Binding Settings.OpenThirdPartyNoticesCommand}" Content="第三方声明" />
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <TextBlock Foreground="#5F6472" TextWrapping="Wrap" Text="{Binding Settings.StatusMessage}" />
                  <Button Classes="sourceAction" Command="{Binding Settings.SaveCommand}" Content="保存设置" />
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Popup>

          <Popup IsLightDismissEnabled="True" IsOpen="{Binding Settings.IsAboutPopupOpen}" Placement="Bottom" PlacementTarget="{Binding #SettingsButton}">
            <Border Classes="popupPanel" Width="560" MaxHeight="780" Padding="20">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="20" FontWeight="SemiBold" Text="关于 / Credits" />
                      <TextBlock Opacity="0.68" TextWrapping="Wrap" Text="Windows 版移植的版本信息、运行环境、TMDB 归属和第三方组件鸣谢。" />
                    </StackPanel>
                    <Button Grid.Column="1" Margin="12,0,0,0" Classes="sourceAction" Command="{Binding Settings.CloseAboutCommand}" Content="关闭" VerticalAlignment="Top" />
                  </Grid>

                  <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel Spacing="10">
                      <TextBlock FontWeight="SemiBold" Text="应用信息" />
                      <Border Background="#FFFFFF" BorderBrush="#E1E4EB" BorderThickness="1" CornerRadius="14" Padding="12">
                        <StackPanel Spacing="6">
                          <TextBlock FontWeight="SemiBold" Text="OmniPlay Windows" />
                          <TextBlock Opacity="0.74" Text="{Binding Settings.AppVersionText, StringFormat=版本 {0}}" />
                          <TextBlock Opacity="0.68" TextWrapping="Wrap" Text="{Binding Settings.RuntimeText}" />
                          <TextBlock Opacity="0.68" TextWrapping="Wrap" Text="{Binding Settings.PlatformText}" />
                          <TextBlock Opacity="0.58" TextWrapping="Wrap" Text="{Binding Settings.SettingsDirectoryPath, StringFormat=设置目录：{0}}" />
                          <TextBlock Opacity="0.58" TextWrapping="Wrap" Text="{Binding Settings.ThirdPartyNoticesPath, StringFormat=第三方声明：{0}}" />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Classes="sourceAction" Command="{Binding Settings.OpenSettingsDirectoryCommand}" Content="打开设置目录" />
                            <Button Classes="sourceAction" Command="{Binding Settings.OpenThirdPartyNoticesCommand}" Content="查看 THIRD_PARTY_NOTICES" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>

                  <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel Spacing="12">
                      <TextBlock FontWeight="SemiBold" Text="TMDB Credits" />
                      <Border Background="#FFFFFF" BorderBrush="#DDE5EA" BorderThickness="1" CornerRadius="14" Padding="14,12">
                        <StackPanel Spacing="8">
                          <brand:TmdbLogo Height="26" HorizontalAlignment="Left" />
                          <TextBlock Opacity="0.58" Text="Official approved logo" />
                        </StackPanel>
                      </Border>
                      <Border Background="#FFF6E7" BorderBrush="#F0D7A1" BorderThickness="1" CornerRadius="14" Padding="12">
                        <StackPanel Spacing="6">
                          <TextBlock FontWeight="SemiBold" Text="TMDB 归属与限制" />
                          <TextBlock Opacity="0.82" TextWrapping="Wrap" Text="内置公共源是共享 TMDB Key，仅提供低频、轻量刮削。为遵守 TMDB 官方要求，公共源会限制搜索请求量，不补全单集剧照；大批量扫库或完整刮削请填写你自己的 API Key。" />
                          <TextBlock Opacity="0.72" TextWrapping="Wrap" Text="This product uses the TMDB API but is not endorsed or certified by TMDB." />
                        </StackPanel>
                      </Border>
                      <TextBlock Opacity="0.62" TextWrapping="Wrap" Text="按 TMDB FAQ 建议，这里保留归属声明、官方 logo 和官方链接入口，方便查看 FAQ、官网与 API 条款。" />
                      <StackPanel Spacing="8">
                        <Button Classes="sourceAction" Command="{Binding Settings.OpenTmdbWebsiteCommand}" Content="打开 TMDB 官网" />
                        <Button Classes="sourceAction" Command="{Binding Settings.OpenTmdbFaqCommand}" Content="打开 TMDB FAQ / Attribution" />
                        <Button Classes="sourceAction" Command="{Binding Settings.OpenTmdbApiTermsCommand}" Content="打开 TMDB API 条款" />
                      </StackPanel>
                    </StackPanel>
                  </Border>

                  <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="16">
                    <StackPanel Spacing="12">
                      <TextBlock FontWeight="SemiBold" Text="开源与服务鸣谢" />
                      <TextBlock Opacity="0.66" TextWrapping="Wrap" Text="以下组件为 Windows 版界面、数据库、日志、测试和播放能力提供支持。列表包含组件名称、许可证和官网入口；完整说明见 THIRD_PARTY_NOTICES。" />
                      <ItemsControl ItemsSource="{Binding Settings.CreditLinks}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Margin="0,0,0,10" Background="#FFFFFF" BorderBrush="#E1E4EB" BorderThickness="1" CornerRadius="14" Padding="12">
                              <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                <TextBlock Opacity="0.68" TextWrapping="Wrap" Text="{Binding Description}" />
                                <TextBlock Opacity="0.58" Text="{Binding License, StringFormat=许可证：{0}}" />
                                <Button Classes="sourceAction"
                                        Command="{Binding $parent[UserControl].DataContext.Settings.OpenCreditLinkCommand}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding ButtonText}" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </Border>
          </Popup>

          <StackPanel Margin="0,-18,0,0" Spacing="14" IsVisible="{Binding HasContinueWatching}">
            <TextBlock FontSize="38" FontWeight="Black" Text="&#x7EE7;&#x7EED;&#x64AD;&#x653E;" />
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding ContinueWatchingItems}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Width="204" Margin="0,0,20,0">
                      <StackPanel Width="204" Spacing="0">
                        <Grid Classes="posterInteractive" Width="204" Height="306" ClipToBounds="True">
                          <Button Classes="cardButton" Command="{Binding $parent[UserControl].DataContext.OpenDetailCommand}" CommandParameter="{Binding}">
                            <Grid Width="204" Height="306">
                              <Border Classes="posterShell" CornerRadius="18" />
                              <Rectangle RadiusX="18" RadiusY="18">
                                <Rectangle.Fill>
                                  <ImageBrush Source="{Binding PosterPath, Converter={StaticResource ImagePathToBitmapConverter}}" Stretch="UniformToFill" />
                                </Rectangle.Fill>
                              </Rectangle>
                              <Border Classes="ratingBadge" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10">
                                <TextBlock Foreground="#FFD700" FontSize="14" FontWeight="Bold" Text="{Binding VoteAverage, StringFormat={}{0:F1}}" />
                              </Border>
                            </Grid>
                          </Button>
                          <StackPanel Classes="posterQuickActions" HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal" Spacing="8" Margin="0,10,10,0">
                            <Button Classes="posterQuickAction" Command="{Binding $parent[UserControl].DataContext.OpenPosterScrapeCommand}" CommandParameter="{Binding}" ToolTip.Tip="搜索刮削">
                              <Path Data="M17.5,17.5 L21,21 M10.5,18 A7.5,7.5 0 1 1 10.5,3 A7.5,7.5 0 0 1 10.5,18 Z" />
                            </Button>
                            <Button Classes="posterQuickAction" Command="{Binding $parent[UserControl].DataContext.OpenPosterEditCommand}" CommandParameter="{Binding}" ToolTip.Tip="自定义编辑">
                              <Path Data="M5,17.5 L5,21 L8.5,21 L19.5,10 L16,6.5 Z M14.5,8 L18,11.5" />
                            </Button>
                          </StackPanel>
                        </Grid>
                        <StackPanel Width="204" Spacing="0">
                          <Button Classes="cardButton" Command="{Binding $parent[UserControl].DataContext.OpenDetailCommand}" CommandParameter="{Binding}">
                            <TextBlock Margin="0,12,0,0" Width="204" MinHeight="46" FontSize="18" FontWeight="Bold" LineHeight="23" Text="{Binding Title}" MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                          </Button>
                          <Grid Margin="0,6,0,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <Button Classes="cardButton" Command="{Binding $parent[UserControl].DataContext.OpenDetailCommand}" CommandParameter="{Binding}">
                              <TextBlock Width="166" FontSize="14" Foreground="#8A8A92" VerticalAlignment="Center" Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis" />
                            </Button>
                            <Button
                                Grid.Column="1"
                                Classes="watchStateButton"
                                Margin="8,0,0,0"
                                Command="{Binding $parent[UserControl].DataContext.OpenPosterWatchStateConfirmationCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="{Binding WatchStateText}">
                              <Grid Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid IsVisible="{Binding IsWatchedState}">
                                  <Ellipse Classes="watchStateRing" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                  <Ellipse Classes="watchStateDot" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <Path Classes="watchStateIcon" Data="M9,1.8 A7.2,7.2 0 1 1 9,16.2 A7.2,7.2 0 1 1 9,1.8" IsVisible="{Binding IsInProgressState}" />
                                <Path Classes="watchStateIcon" Data="M9,1.8 A7.2,7.2 0 1 1 9,16.2 A7.2,7.2 0 1 1 9,1.8" IsVisible="{Binding IsUnwatchedState}" />
                              </Grid>
                            </Button>
                          </Grid>
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>

          <Border Classes="sectionDivider" Margin="0,8,0,6" IsVisible="{Binding HasContinueWatching}" />

          <StackPanel Spacing="22">
            <Grid ColumnDefinitions="Auto,Auto,*" VerticalAlignment="Center" Margin="0,4,0,0">
              <TextBlock FontSize="38" FontWeight="Black" Text="&#x6240;&#x6709;&#x5F71;&#x89C6;" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="18,0,0,0" VerticalAlignment="Center">
                <Button x:Name="SearchButton" Classes="flatIcon" Command="{Binding ToggleSearchPopupCommand}" ToolTip.Tip="&#x641C;&#x7D22;&#x6807;&#x9898;">
                  <Path Classes="iconStroke" Data="M19.5,19.5 L24,24 M10.5,18 A7.5,7.5 0 1 1 10.5,3 A7.5,7.5 0 0 1 10.5,18 Z" />
                </Button>
                <Button x:Name="SortButton" Classes="flatIcon" Command="{Binding ToggleSortPopupCommand}" ToolTip.Tip="&#x6392;&#x5E8F;&#x65B9;&#x5F0F;">
                  <Path Classes="iconStroke" Data="M6,7 H22 M9,13 H19 M12,19 H16" />
                </Button>
                <Button Classes="flatIcon" Command="{Binding ToggleSortDirectionCommand}" ToolTip.Tip="{Binding SortDirectionToolTip}">
                  <Grid Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Path Classes="iconStroke" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsSortAscending}" Data="M14,22 V7 M14,7 L8,13 M14,7 L20,13" />
                    <Path Classes="iconStroke" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsSortDescending}" Data="M14,6 V21 M14,21 L8,15 M14,21 L20,15" />
                  </Grid>
                </Button>
              </StackPanel>
            </Grid>

              <ItemsControl x:Name="LibraryItemsControl" ItemsSource="{Binding LibraryItems}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" ItemWidth="224" ItemHeight="444" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Width="204">
                      <StackPanel Width="204" Margin="0,0,0,22" Spacing="0">
                        <Grid Classes="posterInteractive" Width="204" Height="306" ClipToBounds="True">
                          <Button Classes="cardButton" Command="{Binding $parent[UserControl].DataContext.OpenDetailCommand}" CommandParameter="{Binding}">
                            <Grid Width="204" Height="306">
                              <Border Classes="posterShell" CornerRadius="18" />
                              <Rectangle RadiusX="18" RadiusY="18">
                                <Rectangle.Fill>
                                  <ImageBrush Source="{Binding PosterPath, Converter={StaticResource ImagePathToBitmapConverter}}" Stretch="UniformToFill" />
                                </Rectangle.Fill>
                              </Rectangle>
                              <Border Classes="ratingBadge" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10">
                                <TextBlock Foreground="#FFD700" FontSize="14" FontWeight="Bold" Text="{Binding VoteAverage, StringFormat={}{0:F1}}" />
                              </Border>
                            </Grid>
                          </Button>
                          <StackPanel Classes="posterQuickActions" HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal" Spacing="8" Margin="0,10,10,0">
                            <Button Classes="posterQuickAction" Command="{Binding $parent[UserControl].DataContext.OpenPosterScrapeCommand}" CommandParameter="{Binding}" ToolTip.Tip="搜索刮削">
                              <Path Data="M17.5,17.5 L21,21 M10.5,18 A7.5,7.5 0 1 1 10.5,3 A7.5,7.5 0 0 1 10.5,18 Z" />
                            </Button>
                            <Button Classes="posterQuickAction" Command="{Binding $parent[UserControl].DataContext.OpenPosterEditCommand}" CommandParameter="{Binding}" ToolTip.Tip="自定义编辑">
                              <Path Data="M5,17.5 L5,21 L8.5,21 L19.5,10 L16,6.5 Z M14.5,8 L18,11.5" />
                            </Button>
                          </StackPanel>
                        </Grid>
                        <StackPanel Width="204" Spacing="0">
                          <Button Classes="cardButton" Command="{Binding $parent[UserControl].DataContext.OpenDetailCommand}" CommandParameter="{Binding}">
                            <TextBlock Margin="0,12,0,0" Width="204" MinHeight="46" FontSize="18" FontWeight="Bold" LineHeight="23" Text="{Binding Title}" MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                          </Button>
                          <Grid Margin="0,6,0,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                            <Button Classes="cardButton" Command="{Binding $parent[UserControl].DataContext.OpenDetailCommand}" CommandParameter="{Binding}">
                              <TextBlock Width="166" FontSize="14" Foreground="#8A8A92" VerticalAlignment="Center" Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis" />
                            </Button>
                            <Button
                                Grid.Column="1"
                                Classes="watchStateButton"
                                Margin="8,0,0,0"
                                Command="{Binding $parent[UserControl].DataContext.OpenPosterWatchStateConfirmationCommand}"
                                CommandParameter="{Binding}"
                                ToolTip.Tip="{Binding WatchStateText}">
                              <Grid Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid IsVisible="{Binding IsWatchedState}">
                                  <Ellipse Classes="watchStateRing" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                  <Ellipse Classes="watchStateDot" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <Path Classes="watchStateIcon" Data="M9,1.8 A7.2,7.2 0 1 1 9,16.2 A7.2,7.2 0 1 1 9,1.8" IsVisible="{Binding IsInProgressState}" />
                                <Path Classes="watchStateIcon" Data="M9,1.8 A7.2,7.2 0 1 1 9,16.2 A7.2,7.2 0 1 1 9,1.8" IsVisible="{Binding IsUnwatchedState}" />
                              </Grid>
                            </Button>
                          </Grid>
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="0" Classes="detailSurface" IsVisible="{Binding IsDetailOpen}">
      <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="58,44,58,48" Spacing="42">
          <Grid ColumnDefinitions="Auto,*">
            <Button Classes="iconCircle" Command="{Binding CloseDetailCommand}">
              <Path Classes="iconStroke" Data="M18,5 L8,14 L18,23" />
            </Button>
          </Grid>

          <Grid ColumnDefinitions="460,*">
            <Grid Width="460" Height="690" HorizontalAlignment="Left">
              <Border Classes="posterShell" CornerRadius="30" />
              <Rectangle RadiusX="30" RadiusY="30">
                <Rectangle.Fill>
                  <ImageBrush Source="{Binding DetailPosterPath, Converter={StaticResource ImagePathToBitmapConverter}, TargetNullValue={x:Null}, FallbackValue={x:Null}}" Stretch="UniformToFill" />
                </Rectangle.Fill>
              </Rectangle>
            </Grid>

            <StackPanel Grid.Column="1" Margin="54,0,0,0" Spacing="24" VerticalAlignment="Top">
              <TextBlock FontSize="74" FontWeight="Black" LineHeight="82" Text="{Binding DetailTitle}" TextWrapping="Wrap" MaxWidth="1180" />
              <WrapPanel Orientation="Horizontal">
                <Border Classes="detailMetaBadge" Margin="0,0,14,12">
                  <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#777A84" Text="{Binding DetailMeta}" />
                </Border>
                <Border Classes="detailMetaBadge" Margin="0,0,14,12">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="22" Foreground="#F5A000" Text="&#x2605;" />
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="#F5A000" Text="{Binding DetailRatingText}" />
                  </StackPanel>
                </Border>
              </WrapPanel>

              <Border Classes="detailPanel" Padding="28">
                <TextBlock FontSize="21" LineHeight="34" Foreground="#202127" MaxWidth="1240" Text="{Binding DetailOverview}" TextWrapping="Wrap" />
              </Border>

              <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Classes="heroAction" Command="{Binding PlayPrimaryCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="14">
                    <Path Classes="iconFill" Width="20" Height="20" Fill="#FFFFFF" Data="M6,4 L23,14 L6,24 Z" />
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" Text="{Binding DetailPrimaryActionText}" />
                  </StackPanel>
                </Button>
                <Button Classes="heroSecondary" Command="{Binding ToggleDetailWatchedCommand}" CommandParameter="{Binding DetailPrimaryFile}">
                  <StackPanel Orientation="Horizontal" Spacing="14">
                    <Ellipse Width="16" Height="16" Stroke="#111215" StrokeThickness="2" />
                    <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding DetailWatchedActionText}" />
                  </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" IsVisible="{Binding CanShowDetailPrimaryProgress}">
                  <ProgressBar Classes="libraryProgress" Width="160" Height="6" Minimum="0" Maximum="1" Value="{Binding DetailPlaybackProgressRatio}" />
                  <TextBlock FontSize="15" Foreground="#6F7380" Text="{Binding DetailPrimaryTimeText}" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Grid>

          <StackPanel Spacing="22" IsVisible="{Binding IsDetailSeries}">
            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
              <ComboBox Classes="popupSelect" MinWidth="190" ItemsSource="{Binding AvailableSeasons}" SelectedItem="{Binding SelectedSeasonOption, Mode=TwoWay}" IsVisible="{Binding HasSeasonTabs}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding StringFormat=第 {0} 季}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center" IsVisible="{Binding !HasSeasonTabs}">
                <Path Classes="iconStroke" Stroke="#31343D" Data="M6,10 L14,18 L22,10" />
                <TextBlock FontSize="30" FontWeight="Black" Text="{Binding StringFormat=第 {0} 季, Path=SelectedSeason}" />
              </StackPanel>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding DetailFiles}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" ItemWidth="430" ItemHeight="360" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Width="398" Margin="0,0,26,20" Spacing="12">
                    <StackPanel Spacing="12">
                      <Grid Classes="posterInteractive" Width="398" Height="224" ClipToBounds="True">
                        <Button Classes="cardButton" Command="{Binding $parent[UserControl].DataContext.SelectDetailFileCommand}" CommandParameter="{Binding}">
                          <Grid Width="398" Height="224">
                          <Border Classes="posterShell" CornerRadius="22" />
                          <Rectangle RadiusX="22" RadiusY="22">
                            <Rectangle.Fill>
                              <ImageBrush Source="{Binding PreviewImagePath, Converter={StaticResource ImagePathToBitmapConverter}}" Stretch="UniformToFill" />
                            </Rectangle.Fill>
                          </Rectangle>
                          <Border Background="#000000" CornerRadius="22" Opacity="{Binding EpisodeThumbnailDimOpacity}" />
                          </Grid>
                        </Button>
                        <StackPanel Classes="posterQuickActions" HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal" Spacing="8" Margin="0,14,14,0">
                          <Button Classes="posterQuickAction" Command="{Binding $parent[UserControl].DataContext.OpenEpisodeEditCommand}" CommandParameter="{Binding}" ToolTip.Tip="自定义编辑">
                            <Path Data="M5,17.5 L5,21 L8.5,21 L19.5,10 L16,6.5 Z M14.5,8 L18,11.5" />
                          </Button>
                        </StackPanel>
                      </Grid>
                      <StackPanel Spacing="5" MinHeight="62">
                        <TextBlock FontSize="21" FontWeight="Bold" MinHeight="34" HorizontalAlignment="Center" TextAlignment="Center" Text="{Binding EpisodeDisplayTitle}" TextWrapping="NoWrap" />
                        <TextBlock FontSize="15" Foreground="#6F7380" MinHeight="22" HorizontalAlignment="Center" TextAlignment="Center" Text="{Binding EpisodeDisplaySubtitle}" TextWrapping="Wrap" MaxLines="2" IsVisible="{Binding HasEpisodeDisplaySubtitle}" />
                        <ProgressBar Classes="libraryProgress" Width="398" Height="6" Minimum="0" Maximum="1" Value="{Binding ProgressRatio}" IsVisible="{Binding ShouldShowEpisodeProgress}" />
                      </StackPanel>
                    </StackPanel>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <Border IsVisible="{Binding !HasDetailFiles}" Background="#F7F7FA" BorderBrush="#DADCE4" BorderThickness="1" CornerRadius="24" Padding="24">
            <StackPanel Spacing="8">
              <TextBlock FontSize="22" FontWeight="Bold" Text="&#x8FD8;&#x6CA1;&#x6709;&#x53EF;&#x64AD;&#x653E;&#x6587;&#x4EF6;" />
              <TextBlock FontSize="18" Foreground="#7C7E88" Text="&#x8BF7;&#x5148;&#x6DFB;&#x52A0;&#x89C6;&#x9891;&#x76EE;&#x5F55;&#x5E76;&#x6267;&#x884C;&#x626B;&#x63CF;&#x3002;" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Grid.RowSpan="2" ZIndex="85" Background="#AA101114" IsVisible="{Binding IsPosterWatchStateConfirmationOpen}">
      <Grid>
        <Border Classes="popupPanel" Width="540" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
          <StackPanel Spacing="18">
            <TextBlock FontSize="26" FontWeight="Black" Text="{Binding PosterWatchStateConfirmationTitle}" />
            <TextBlock FontSize="17" LineHeight="27" Foreground="#343844" Text="{Binding PosterWatchStateConfirmationMessage}" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
              <Button Classes="sourceAction" Command="{Binding CancelPosterWatchStateConfirmationCommand}" Content="取消" />
              <Button
                  Classes="sourceAction"
                  Background="#267CFF"
                  BorderBrush="#267CFF"
                  Foreground="#FFFFFF"
                  Command="{Binding ConfirmPosterWatchStateCommand}">
                <TextBlock FontWeight="Bold" Foreground="#FFFFFF" Text="{Binding PosterWatchStateConfirmationActionText}" />
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Border Grid.RowSpan="2" ZIndex="80" Background="#AA101114" IsVisible="{Binding IsPosterScrapePanelOpen}">
      <Grid>
        <Border Classes="popupPanel" Width="840" MaxHeight="780" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="6">
                  <TextBlock FontSize="26" FontWeight="Black" Text="{Binding PosterPanelTitle}" />
                  <TextBlock Foreground="#69707D" Text="按当前条目重新搜索 TMDB，选择候选结果后会直接关联并更新海报、简介、评分和年份。" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Classes="sourceAction" Command="{Binding ClosePosterScrapeCommand}" Content="关闭" VerticalAlignment="Top" />
              </Grid>

              <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="16" Padding="14,12">
                <StackPanel Spacing="5">
                  <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#6F7380" Text="源文件" />
                  <TextBlock FontSize="15" Foreground="#202127" Text="{Binding PosterSourceFileText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="*,140,Auto">
                <TextBox Classes="popupSearchBox" Watermark="输入正确片名或剧名" Text="{Binding PosterScrapeQuery}" />
                <TextBox Grid.Column="1" Margin="12,0,0,0" Classes="popupSearchBox" Watermark="上映年份" Text="{Binding PosterScrapeYear}" />
                <Button Grid.Column="2" Margin="12,0,0,0" Classes="sourceAction" Command="{Binding SearchPosterMetadataCandidatesCommand}" Content="搜索候选" />
              </Grid>

              <TextBlock Foreground="#69707D" Text="{Binding PosterScrapeStatus}" TextWrapping="Wrap" />

              <ItemsControl ItemsSource="{Binding PosterMetadataCandidates}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,12">
                      <Grid ColumnDefinitions="76,*,Auto">
                        <Border Width="76" Height="114" CornerRadius="12" ClipToBounds="True" Background="#E6E8F0">
                          <Rectangle>
                            <Rectangle.Fill>
                              <ImageBrush Source="{Binding PreviewImagePath, Converter={StaticResource ImagePathToBitmapConverter}}" Stretch="UniformToFill" />
                            </Rectangle.Fill>
                          </Rectangle>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,16,0" Spacing="6">
                          <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding Title}" TextWrapping="Wrap" />
                          <TextBlock FontSize="14" Foreground="#7B808E" Text="{Binding OriginalTitleText}" TextWrapping="Wrap" IsVisible="{Binding HasOriginalTitle}" />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="detailMetaBadge" Padding="10,5">
                              <TextBlock FontSize="13" FontWeight="Bold" Foreground="#6C7180" Text="{Binding MediaTypeText}" />
                            </Border>
                            <TextBlock FontSize="15" VerticalAlignment="Center" Foreground="#69707D" Text="{Binding MatchMetaText}" />
                          </StackPanel>
                          <TextBlock FontSize="15" Foreground="#31343D" Text="{Binding OverviewText}" TextWrapping="Wrap" MaxLines="3" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="2" Classes="sourceAction" Command="{Binding $parent[UserControl].DataContext.ApplyPosterMetadataCandidateCommand}" CommandParameter="{Binding}" Content="关联此项" VerticalAlignment="Center" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Border>

    <Border Grid.RowSpan="2" ZIndex="80" Background="#AA101114" IsVisible="{Binding IsPosterEditPanelOpen}">
      <Grid>
        <Border Classes="popupPanel" Width="660" MaxHeight="760" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="6">
                  <TextBlock FontSize="26" FontWeight="Black" Text="{Binding PosterPanelTitle}" />
                  <TextBlock Foreground="#69707D" Text="保存后会锁定此条目，后续自动刮削不会覆盖手动资料。" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Classes="sourceAction" Command="{Binding ClosePosterEditCommand}" Content="取消" VerticalAlignment="Top" />
              </Grid>

              <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="16" Padding="14,12">
                <StackPanel Spacing="5">
                  <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#6F7380" Text="源文件" />
                  <TextBlock FontSize="15" Foreground="#202127" Text="{Binding PosterSourceFileText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <StackPanel Spacing="12">
                <TextBlock FontWeight="SemiBold" Text="名称" />
                <TextBox Classes="popupSearchBox" Watermark="影视名称" Text="{Binding PosterEditTitle}" />
              </StackPanel>

              <Grid ColumnDefinitions="*,160">
                <StackPanel Spacing="12">
                  <TextBlock FontWeight="SemiBold" Text="年份 / 日期" />
                  <TextBox Classes="popupSearchBox" Watermark="例如 2025 或 2025-01-01" Text="{Binding PosterEditDate}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="12">
                  <TextBlock FontWeight="SemiBold" Text="评分" />
                  <TextBox Classes="popupSearchBox" Watermark="0.0 - 10.0" Text="{Binding PosterEditVoteAverage}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="12">
                <TextBlock FontWeight="SemiBold" Text="简介" />
                <TextBox Classes="popupSearchBox" MinHeight="120" AcceptsReturn="True" TextWrapping="Wrap" Watermark="剧情简介" Text="{Binding PosterEditOverview}" />
              </StackPanel>

              <StackPanel Spacing="12">
                <TextBlock FontWeight="SemiBold" Text="海报" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Classes="popupSearchBox" Watermark="海报本地路径" Text="{Binding PosterEditPosterPath}" />
                  <Button Grid.Column="1" Margin="12,0,0,0" Classes="sourceAction" Command="{Binding ChoosePosterImageCommand}" Content="选择图片..." />
                </Grid>
              </StackPanel>

              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button Classes="sourceAction" Command="{Binding ClosePosterEditCommand}" Content="取消" />
                <Button Classes="heroAction" Command="{Binding SavePosterMetadataEditCommand}">
                  <TextBlock FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" Text="保存并锁定" />
                </Button>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Border>

    <Border Grid.RowSpan="2" ZIndex="80" Background="#AA101114" IsVisible="{Binding IsEpisodeEditPanelOpen}">
      <Grid>
        <Border Classes="popupPanel" Width="620" MaxHeight="720" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="6">
                  <TextBlock FontSize="26" FontWeight="Black" Text="{Binding EpisodeEditPanelTitle}" />
                  <TextBlock Foreground="#69707D" Text="保存后会覆盖此分集的年份、副标题、季数、集数和自定义剧照；剧照刮削会按季数和集数匹配。" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Classes="sourceAction" Command="{Binding CloseEpisodeEditCommand}" Content="取消" VerticalAlignment="Top" />
              </Grid>

              <Border Background="#F8F8FB" BorderBrush="#E0E2EA" BorderThickness="1" CornerRadius="16" Padding="14,12">
                <StackPanel Spacing="5">
                  <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#6F7380" Text="源文件" />
                  <TextBlock FontSize="15" Foreground="#202127" Text="{Binding EpisodeEditSourceFileText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Grid ColumnDefinitions="*,*">
                <StackPanel Spacing="12">
                  <TextBlock FontWeight="SemiBold" Text="季数" />
                  <TextBox Classes="popupSearchBox" Watermark="例如 1；特别篇可填 0" Text="{Binding EpisodeEditSeason}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="12">
                  <TextBlock FontWeight="SemiBold" Text="集数" />
                  <TextBox Classes="popupSearchBox" Watermark="例如 1" Text="{Binding EpisodeEditEpisode}" />
                </StackPanel>
              </Grid>

              <StackPanel Spacing="12">
                <TextBlock FontWeight="SemiBold" Text="年份" />
                <TextBox Classes="popupSearchBox" Watermark="例如 2025" Text="{Binding EpisodeEditYear}" />
              </StackPanel>

              <StackPanel Spacing="12">
                <TextBlock FontWeight="SemiBold" Text="副标题" />
                <TextBox Classes="popupSearchBox" Watermark="例如 嘉宾名 / 主题 / 上半场" Text="{Binding EpisodeEditSubtitle}" />
              </StackPanel>

              <StackPanel Spacing="12">
                <TextBlock FontWeight="SemiBold" Text="分集剧照" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Classes="popupSearchBox" Watermark="分集剧照本地路径" Text="{Binding EpisodeEditThumbnailPath}" />
                  <Button Grid.Column="1" Margin="12,0,0,0" Classes="sourceAction" Command="{Binding ChooseEpisodeThumbnailImageCommand}" Content="选择图片..." />
                </Grid>
              </StackPanel>

              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button Classes="sourceAction" Command="{Binding CloseEpisodeEditCommand}" Content="取消" />
                <Button Classes="heroAction" Command="{Binding SaveEpisodeEditCommand}">
                  <TextBlock FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" Text="保存" />
                </Button>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Border>

    <Border
        x:Name="OverlayPlaybackRoot"
        Grid.RowSpan="2"
        ZIndex="100"
        Background="#000000"
        Focusable="True"
        IsVisible="{Binding IsPlayerOverlayOpen}"
        PointerMoved="Overlay_OnPointerMoved">
      <Grid Background="#000000">
        <ContentControl
            x:Name="OverlayPlayerSurfaceHostContainer"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />

        <Border
            x:Name="OverlayTapSurface"
            Background="#01000000"
            PointerPressed="OverlayTapSurface_OnPointerPressed" />

        <Border
            x:Name="OverlayWindowControlsAnchor"
            Width="1"
            Height="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            IsHitTestVisible="False"
            Opacity="0" />

        <Border
            x:Name="OverlayBottomPopupAnchor"
            Height="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            IsHitTestVisible="False"
            Opacity="0" />

        <Popup
            x:Name="OverlayWindowControlsPopup"
            IsLightDismissEnabled="False"
            Placement="BottomEdgeAlignedLeft"
            PlacementTarget="{Binding #OverlayWindowControlsAnchor}"
            Topmost="True">
          <Border
              x:Name="OverlayWindowControlsPanel"
              Width="{Binding #OverlayPlaybackRoot.Bounds.Width}"
              Height="48"
              Background="#66000000"
              PointerEntered="OverlayWindowControlsPanel_OnPointerEntered"
              PointerExited="OverlayWindowControlsPanel_OnPointerExited"
              PointerMoved="OverlayWindowControlsPanel_OnPointerMoved"
              IsVisible="False">
            <StackPanel
                Margin="12,10,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Orientation="Horizontal">
              <Button Width="14" Height="14" Margin="0,0,8,0" Padding="0" Background="#FF5F57" BorderBrush="#33000000" BorderThickness="1" CornerRadius="7" Click="OverlayCloseButton_OnClick" ToolTip.Tip="关闭播放页" />
              <Button Width="14" Height="14" Margin="0,0,8,0" Padding="0" Background="#FFBD2E" BorderBrush="#33000000" BorderThickness="1" CornerRadius="7" Click="OverlayMinimizeButton_OnClick" ToolTip.Tip="最小化" />
              <Button
                  x:Name="OverlayMaximizeButton"
                  Width="14"
                  Height="14"
                  Padding="0"
                  Background="#28C840"
                  BorderBrush="#33000000"
                  BorderThickness="1"
                  CornerRadius="7"
                  PointerPressed="OverlayMaximizeButton_OnPointerPressed"
                  ToolTip.Tip="最大化或还原" />
            </StackPanel>
          </Border>
        </Popup>

        <Popup
            x:Name="OverlayWindowControlsHotZonePopup"
            IsLightDismissEnabled="False"
            Placement="BottomEdgeAlignedLeft"
            PlacementTarget="{Binding #OverlayWindowControlsAnchor}"
            Topmost="True">
          <Border
              Width="{Binding #OverlayPlaybackRoot.Bounds.Width}"
              Height="48"
              Background="#01000000"
              PointerEntered="OverlayWindowControlsHotZone_OnPointerActivity"
              PointerMoved="OverlayWindowControlsHotZone_OnPointerActivity" />
        </Popup>

        <Popup
            x:Name="OverlayStatusPopup"
            IsLightDismissEnabled="False"
            Placement="Center"
            PlacementTarget="{Binding #OverlayPlaybackRoot}"
            Topmost="True">
          <Border
              MaxWidth="520"
              Padding="16,11"
              CornerRadius="14"
              Background="#B3000000"
              BorderBrush="#22FFFFFF"
              BorderThickness="1">
            <TextBlock
                Foreground="#F5F5F5"
                Text="{Binding Player.StatusMessage}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
          </Border>
        </Popup>

        <Popup
            x:Name="OverlayControlsPopup"
            IsLightDismissEnabled="False"
            Placement="TopEdgeAlignedLeft"
            PlacementTarget="{Binding #OverlayBottomPopupAnchor}"
            Topmost="True">
          <Border
              Width="{Binding #OverlayPlaybackRoot.Bounds.Width}"
              PointerMoved="OverlayControlsArea_OnPointerMoved">
            <Border.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#00000000" Offset="0" />
                <GradientStop Color="#C2000000" Offset="0.34" />
                <GradientStop Color="#F2000000" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="30,46,30,30" RowDefinitions="Auto,Auto,Auto,Auto">
              <Button
                  Grid.Row="0"
                  MinHeight="42"
                  Padding="18,0"
                  HorizontalAlignment="Right"
                  Background="#2C7DFF"
                  BorderBrush="#2C7DFF"
                  BorderThickness="1"
                  CornerRadius="14"
                  Foreground="#FFFFFF"
                  FontWeight="SemiBold"
                  Command="{Binding Player.PlayNextEpisodeCommand}"
                  Content="{Binding Player.NextEpisodeActionText}"
                  IsVisible="{Binding Player.ShouldShowNextEpisodeAction}" />

              <Grid Grid.Row="1" Margin="0,0,0,8" ColumnDefinitions="*,Auto,*">
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="34">
                  <Button
                      Width="58"
                      Height="58"
                      Padding="0"
                      Background="#99000000"
                      BorderBrush="#30FFFFFF"
                      BorderThickness="1"
                      CornerRadius="29"
                      Foreground="#FFFFFF"
                      Command="{Binding Player.SeekBackwardCommand}"
                      ToolTip.Tip="后退 10 秒">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="SemiBold" Text="&lt;" />
                  </Button>
                  <Button
                      Width="76"
                      Height="76"
                      Padding="0"
                      Background="#F3F1EC"
                      BorderThickness="0"
                      CornerRadius="38"
                      Foreground="#111111"
                      Command="{Binding Player.TogglePlayPauseCommand}"
                      ToolTip.Tip="播放或暂停">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="34" Text="{Binding Player.PlayPauseGlyph}" />
                  </Button>
                  <Button
                      Width="58"
                      Height="58"
                      Padding="0"
                      Background="#99000000"
                      BorderBrush="#30FFFFFF"
                      BorderThickness="1"
                      CornerRadius="29"
                      Foreground="#FFFFFF"
                      Command="{Binding Player.SeekForwardCommand}"
                      ToolTip.Tip="前进 10 秒">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="SemiBold" Text="&gt;" />
                  </Button>
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                  <Button
                      Width="46"
                      Height="46"
                      Padding="0"
                      Background="#99000000"
                      BorderBrush="#30FFFFFF"
                      BorderThickness="1"
                      CornerRadius="23"
                      Foreground="#FFFFFF"
                      Command="{Binding Player.ToggleMuteCommand}"
                      ToolTip.Tip="静音切换">
                    <Grid Width="24" Height="22">
                      <Path Width="20" Height="20" Stretch="Uniform" Fill="#FFFFFFFF" Data="M2,8 L6,8 L11,3 L11,21 L6,16 L2,16 Z M15,8 C17,10 17,14 15,16" />
                      <Path Stroke="#FFFFFFFF" StrokeThickness="2" StrokeLineCap="Round" Data="M17,7 L22,12 M22,7 L17,12" IsVisible="{Binding Player.IsMuted}" />
                    </Grid>
                  </Button>
                  <Slider
                      x:Name="OverlayVolumeSlider"
                      Width="126"
                      VerticalAlignment="Center"
                      Minimum="0"
                      Maximum="100"
                      Value="{Binding Player.VolumePercent, Mode=TwoWay}"
                      PropertyChanged="OverlayVolumeSlider_OnPropertyChanged"
                      ToolTip.Tip="{Binding Player.VolumeText}" />
                </StackPanel>
              </Grid>

              <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="Auto,*,Auto">
                <TextBlock
                    MinWidth="54"
                    VerticalAlignment="Center"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="#D0D0D0"
                    Text="{Binding Player.CurrentPositionText}" />
                <Slider
                    x:Name="OverlayPositionSlider"
                    Grid.Column="1"
                    Margin="12,0"
                    Minimum="0"
                    Maximum="{Binding Player.DurationSeconds}"
                    Value="{Binding Player.SeekPositionSeconds, Mode=TwoWay}"
                    PropertyChanged="OverlaySlider_OnPropertyChanged" />
                <TextBlock
                    Grid.Column="2"
                    MinWidth="58"
                    VerticalAlignment="Center"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="#D0D0D0"
                    Text="{Binding Player.RemainingTimeText}" />
              </Grid>

              <StackPanel
                  Grid.Row="3"
                  Margin="0,12,0,0"
                  HorizontalAlignment="Right"
                  Orientation="Horizontal"
                  Spacing="10">
                <Grid>
                  <Button
                      x:Name="OverlayAudioButton"
                      Width="44"
                      Height="38"
                      Padding="0"
                      Background="#B3000000"
                      BorderBrush="#33FFFFFF"
                      BorderThickness="1"
                      CornerRadius="10"
                      Foreground="#F5F5F5"
                      Click="OverlayAudioButton_OnClick"
                      IsVisible="{Binding Player.IsPlaying}"
                      ToolTip.Tip="音频轨道">
                    <Path Width="21" Height="21" Stretch="Uniform" Stroke="#FFFFFFFF" StrokeThickness="1.8" StrokeLineCap="Round" Fill="#00000000" Data="M7,18 V6 L17,4 V15 M7,18 C7,19.4 5.8,20.5 4.3,20.5 C2.8,20.5 1.7,19.6 1.7,18.3 C1.7,17 2.9,16 4.4,16 C5.4,16 6.3,16.4 7,17 M17,15 C17,16.4 15.8,17.5 14.3,17.5 C12.8,17.5 11.7,16.6 11.7,15.3 C11.7,14 12.9,13 14.4,13 C15.4,13 16.3,13.4 17,14" />
                  </Button>
                  <Popup x:Name="OverlayAudioPopup" IsLightDismissEnabled="True" Placement="Top" PlacementTarget="{Binding #OverlayAudioButton}">
                    <Border Width="280" Padding="10" Background="#F20D0D0D" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="10" PointerMoved="OverlayControlsArea_OnPointerMoved">
                      <ItemsControl ItemsSource="{Binding Player.AudioTracks}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button MinHeight="36" Padding="10,0" HorizontalContentAlignment="Stretch" Background="#00000000" BorderThickness="0" Foreground="#F5F5F5" Click="OverlayAudioTrackButton_OnClick">
                              <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="✓" IsVisible="{Binding IsSelected}" />
                              </Grid>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>
                  </Popup>
                </Grid>

                <Grid>
                  <Button
                      x:Name="OverlaySubtitleButton"
                      Width="44"
                      Height="38"
                      Padding="0"
                      Background="#B3000000"
                      BorderBrush="#33FFFFFF"
                      BorderThickness="1"
                      CornerRadius="10"
                      Foreground="#F5F5F5"
                      Click="OverlaySubtitleButton_OnClick"
                      IsVisible="{Binding Player.HasTrackControls}"
                      ToolTip.Tip="字幕">
                    <Path Width="22" Height="18" Stretch="Uniform" Stroke="#FFFFFFFF" StrokeThickness="1.8" StrokeLineCap="Round" Fill="#00000000" Data="M2,3 L22,3 L22,17 L2,17 Z M6,10 L11,10 M13,10 L18,10 M6,14 L17,14" />
                  </Button>
                  <Popup x:Name="OverlaySubtitlePopup" IsLightDismissEnabled="True" Placement="Top" PlacementTarget="{Binding #OverlaySubtitleButton}">
                    <Border Width="320" Padding="12" Background="#F20D0D0D" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="10" PointerMoved="OverlayControlsArea_OnPointerMoved">
                      <StackPanel Spacing="10">
                        <ItemsControl ItemsSource="{Binding Player.SubtitleTracks}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Button MinHeight="34" Padding="10,0" HorizontalContentAlignment="Stretch" Background="#00000000" BorderThickness="0" Foreground="#F5F5F5" Click="OverlaySubtitleTrackButton_OnClick">
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                  <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="✓" IsVisible="{Binding IsSelected}" />
                                </Grid>
                              </Button>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button MinHeight="36" Padding="10,0" HorizontalContentAlignment="Left" Background="#1FFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Foreground="#F5F5F5" Command="{Binding Player.LoadExternalSubtitleCommand}" Content="加载外挂字幕" IsVisible="{Binding Player.HasExternalSubtitlePicker}" />

                        <Grid ColumnDefinitions="Auto,*,Auto" IsVisible="{Binding Player.HasSubtitleStyleControls}">
                          <Button Width="38" Height="34" Padding="0" Background="#1FFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Foreground="#F5F5F5" Command="{Binding Player.DecreaseSubtitleDelayCommand}">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Text="-" />
                          </Button>
                          <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="#F5F5F5" Text="{Binding Player.SubtitleDelayText}" />
                          <Button Grid.Column="2" Width="38" Height="34" Padding="0" Background="#1FFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Foreground="#F5F5F5" Command="{Binding Player.IncreaseSubtitleDelayCommand}">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Text="+" />
                          </Button>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Player.SubtitleSizeOptions}" IsVisible="{Binding Player.HasSubtitleStyleControls}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal" Spacing="8" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Button MinWidth="58" MinHeight="34" Padding="10,0" Background="#1FFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Foreground="#F5F5F5" Click="OverlaySubtitleSizeButton_OnClick" Content="{Binding Label}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </Popup>
                </Grid>
              </StackPanel>
            </Grid>
          </Border>
        </Popup>

        <Popup
            x:Name="OverlayBottomHotZonePopup"
            IsLightDismissEnabled="False"
            Placement="TopEdgeAlignedLeft"
            PlacementTarget="{Binding #OverlayBottomPopupAnchor}"
            Topmost="True">
          <Border
              Width="{Binding #OverlayPlaybackRoot.Bounds.Width}"
              Height="180"
              Background="#01000000"
              PointerEntered="OverlayBottomHotZone_OnPointerActivity"
              PointerMoved="OverlayBottomHotZone_OnPointerActivity"
              PointerPressed="OverlayBottomHotZone_OnPointerPressed" />
        </Popup>
      </Grid>
    </Border>
  </Grid>
</UserControl>
